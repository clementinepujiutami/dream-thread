{
  "expo": {
    "name": "Dream Thread",
    "slug": "dream-thread",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "dreamthread",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#080C0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hong0420.dreamthread",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080C0F"
      },
      "package": "com.hong0420.dreamthread"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ceabc2c8-1be9-49cf-9cac-e22f3cf88867"
      }
    },
    "owner": "hong0420",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ceabc2c8-1be9-49cf-9cac-e22f3cf88867"
    }
  }
}
